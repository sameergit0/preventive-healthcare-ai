# ===============================
# Database
# ===============================
DATABASE_URL="dialect+driver://username:password@host:port/database"

# ===============================
# File Storage
# ===============================
UPLOAD_DIR=uploads
LOG_DIR=logs

# ===============================
# Password Hashing
# ===============================
H_ALGORITHM=bcrypt

# ===============================
# Authentication (JWT)
# ===============================
AK_SECRET_KEY="your-secret-key"
AK_ALGORITHM=HS256
AK_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ===============================
# Base URL
# ===============================
BASE_URL=http://localhost:8000