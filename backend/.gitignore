# ===============================
# Python cache & compiled files
# ===============================
__pycache__/
*.py[cod]
*$py.class

# ===============================
# Build / packaging
# ===============================
build/
dist/
*.egg-info/
wheels/

# ===============================
# Virtual environments
# ===============================
.venv/
venv/
env/
ENV/

# ===============================
# Environment variables (IMPORTANT)
# ===============================
.env
.env.*
!.env.example

# ===============================
# Logs
# ===============================
logs/
*.log

# ===============================
# User uploads (runtime data)
# ===============================
uploads/

# ===============================
# Database (local)
# ===============================
*.db
*.sqlite3

# ===============================
